@model volunteerplatform.Models.ViewModels.IndexViewModel
@{
    ViewData["Title"] = "Profile";
}

<div class="container mt-5">
    <h2 class="fw-bold mb-4">@ViewData["Title"]</h2>
    <partial name="_StatusMessage" model="Model.StatusMessage" />

    <div class="row">
        <div class="col-md-3">
            <div class="list-group shadow-sm mb-4">
                <a asp-action="Index" class="list-group-item list-group-item-action active">Profile Details</a>
                <a asp-action="ChangePassword" class="list-group-item list-group-item-action">Password Settings</a>
                @if (User.IsInRole("Volunteer"))
                {
                    <a asp-action="Achievements" class="list-group-item list-group-item-action">
                        <i class="bi bi-trophy-fill me-2 text-warning"></i>Achievements
                    </a>
                }
            </div>
        </div>
        <div class="row g-4">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Edit Profile</h5>
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FullName" class="form-label small fw-bold"></label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label small fw-bold"></label>
                                <input asp-for="PhoneNumber" class="form-control" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label asp-for="Username" class="form-label small fw-bold"></label>
                                <input asp-for="Username" class="form-control bg-light" disabled />
                            </div>

                            @if (User.IsInRole("Volunteer"))
                            {
                                <div class="col-md-4">
                                    <label asp-for="Age" class="form-label small fw-bold"></label>
                                    <input asp-for="Age" class="form-control" />
                                    <span asp-validation-for="Age" class="text-danger small"></span>
                                </div>
                                <div class="col-md-8">
                                    <label asp-for="Location" class="form-label small fw-bold"></label>
                                    <input asp-for="Location" class="form-control" />
                                    <span asp-validation-for="Location" class="text-danger small"></span>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label small fw-bold">Skills</label>
                                    <input type="hidden" asp-for="Skills" id="SkillsHidden" />
                                    <div class="border rounded-3 p-3 bg-light skill-picker mb-2">
                                        @foreach (var skill in new[] { "Teaching", "IT", "Cooking", "First Aid", "Driving", "Social Media", "Art", "Languages", "Construction", "Animal Care", "Communication", "Organization", "Events", "Design", "Photography" })
                                        {
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input skill-cb" type="checkbox" value="@skill" id="skill_@skill.Replace(" ", "_")" />
                                                <label class="form-check-label small" for="skill_@skill.Replace(" ", "_")">@skill</label>
                                            </div>
                                        }
                                    </div>
                                    <span asp-validation-for="Skills" class="text-danger small"></span>
                                </div>
                                <div class="col-md-12">
                                    <label asp-for="Availability" class="form-label small fw-bold"></label>
                                    <input asp-for="Availability" class="form-control" />
                                    <span asp-validation-for="Availability" class="text-danger small"></span>
                                </div>
                            }

                            @if (User.IsInRole("Organizer"))
                            {
                                <div class="col-md-12">
                                    <label asp-for="OrganizationName" class="form-label small fw-bold"></label>
                                    <input asp-for="OrganizationName" class="form-control" />
                                    <span asp-validation-for="OrganizationName" class="text-danger small"></span>
                                </div>
                            }
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mt-4 py-2 rounded-pill fw-bold shadow-sm">Save Changes</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            @* Settings and Privacy *@
            <div class="list-group shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                <div class="list-group-item bg-light py-3">
                    <h6 class="fw-bold mb-0">Account Settings</h6>
                </div>
                <a asp-action="ChangePassword" class="list-group-item list-group-item-action py-3 d-flex align-items-center">
                    <i class="bi bi-key-fill me-3 text-primary"></i>
                    Change Password
                </a>
                <a asp-action="Achievements" class="list-group-item list-group-item-action py-3 d-flex align-items-center">
                    <i class="bi bi-award-fill me-3 text-warning"></i>
                    My Achievements
                </a>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-shield-lock-fill display-4 text-info mb-3 d-block"></i>
                    <h5 class="fw-bold">Privacy & Data</h5>
                    <p class="text-muted small">Manage your personal information and account status according to GDPR guidelines.</p>
                    
                    <div class="d-grid gap-2">
                        <a asp-action="DownloadPersonalData" class="btn btn-outline-info btn-sm rounded-pill py-2">
                            <i class="bi bi-download me-2"></i>Export My Data
                        </a>
                        <button type="button" class="btn btn-outline-danger btn-sm rounded-pill py-2" data-bs-toggle="modal" data-bs-target="#deleteProfileModal">
                            <i class="bi bi-trash-fill me-2"></i>Delete Account
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteProfileModal" tabindex="-1" aria-labelledby="deleteProfileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <i class="bi bi-exclamation-triangle-fill display-4 text-danger mb-4 d-block"></i>
                <h4 class="fw-bold">Are you absolutely sure?</h4>
                <p class="text-muted">This action cannot be undone. All your profile data, achievements, and mission history will be permanently deleted.</p>
            </div>
            <div class="modal-footer border-0 p-4 pt-0">
                <button type="button" class="btn btn-light w-100 rounded-pill mb-2 py-2" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="DeleteAccount" method="post" class="w-100">
                    <button type="submit" class="btn btn-danger w-100 rounded-pill py-2">Yes, delete my account</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const hiddenSkills = document.getElementById('SkillsHidden');
            const checkboxes = document.querySelectorAll('.skill-cb');

            function updateHiddenValue() {
                const selected = Array.from(checkboxes)
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);
                hiddenSkills.value = selected.join(', ');
            }

            if (hiddenSkills.value) {
                const current = hiddenSkills.value.split(',').map(s => s.trim());
                checkboxes.forEach(cb => {
                    if (current.includes(cb.value)) {
                        cb.checked = true;
                    }
                });
            }

            checkboxes.forEach(cb => {
                cb.addEventListener('change', updateHiddenValue);
            });
        });
    </script>
    <style>
        .skill-picker { max-height: 180px; overflow-y: auto; }
    </style>
}
