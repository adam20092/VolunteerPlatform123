@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header Section -->
            <div class="text-center mb-5">
                <div class="d-inline-block px-4 py-2 bg-light rounded-pill mb-3">
                    <span class="text-primary-custom fw-bold small text-uppercase tracking-wider">Legal Framework</span>
                </div>
                <h1 class="display-4 fw-bold mb-3">Privacy Policy</h1>
                <p class="lead text-muted mx-auto" style="max-width: 700px;">
                    At VolunteerPlatform, we take your privacy seriously. This policy explains how we collect, use, and protect your information when you use our services.
                </p>
                <div class="text-muted small">Last Updated: March 9, 2026</div>
            </div>

            <!-- Main Content Card -->
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-5">
                <div class="card-body p-4 p-md-5">
                    
                    <!-- Section 1: Introduction -->
                    <section class="mb-5">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-primary-light p-3 rounded-3 me-3">
                                <i class="bi bi-info-circle-fill text-primary-custom fs-4"></i>
                            </div>
                            <h3 class="mb-0">1. Introduction</h3>
                        </div>
                        <p>Welcome to VolunteerPlatform ("we," "our," or "us"). We are committed to protecting your personal data and your right to privacy. If you have any questions or concerns about our policy, or our practices with regards to your personal information, please contact us.</p>
                        <p>When you visit our website and use our services, you trust us with your personal information. We take your privacy very seriously. In this privacy policy, we seek to explain to you in the clearest way possible what information we collect, how we use it and what rights you have in relation to it.</p>
                    </section>

                    <hr class="my-5 opacity-10">

                    <!-- Section 2: Information Collection -->
                    <section class="mb-5">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-primary-light p-3 rounded-3 me-3">
                                <i class="bi bi-person-badge-fill text-primary-custom fs-4"></i>
                            </div>
                            <h3 class="mb-0">2. Information We Collect</h3>
                        </div>
                        <p>We collect personal information that you voluntarily provide to us when registering at the VolunteerPlatform, expressing an interest in obtaining information about us or our products and services, when participating in activities on the platform (such as applying for volunteer initiatives) or otherwise contacting us.</p>
                        <ul class="list-group list-group-flush border-0">
                            <li class="list-group-item bg-transparent border-0 ps-0">
                                <i class="bi bi-check2 text-primary-custom me-2"></i><strong>Personal Data:</strong> Name, email address, phone number, and skills.
                            </li>
                            <li class="list-group-item bg-transparent border-0 ps-0">
                                <i class="bi bi-check2 text-primary-custom me-2"></i><strong>Usage Data:</strong> Information on how you use our website, including IP addresses, browser types, and pages visited.
                            </li>
                            <li class="list-group-item bg-transparent border-0 ps-0">
                                <i class="bi bi-check2 text-primary-custom me-2"></i><strong>Donation Data:</strong> If you donate via the platform, we collect transaction information (processed securely through our payment providers).
                            </li>
                        </ul>
                    </section>

                    <hr class="my-5 opacity-10">

                    <!-- Section 3: How We Use Information -->
                    <section class="mb-5">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-primary-light p-3 rounded-3 me-3">
                                <i class="bi bi-gear-fill text-primary-custom fs-4"></i>
                            </div>
                            <h3 class="mb-0">3. How We Use Your Information</h3>
                        </div>
                        <p>We use personal information collected via our website for a variety of business purposes described below:</p>
                        <div class="row g-4 mt-1">
                            <div class="col-md-6">
                                <div class="p-3 border rounded-3 h-100">
                                    <h6 class="fw-bold mb-2">Facilitate Connections</h6>
                                    <p class="small text-muted mb-0">To connect volunteers with appropriate organizations and initiatives based on interests and skills.</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 border rounded-3 h-100">
                                    <h6 class="fw-bold mb-2">Communication</h6>
                                    <p class="small text-muted mb-0">To send you administrative information, marketing communications, and updates about initiatives you follow.</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 border rounded-3 h-100">
                                    <h6 class="fw-bold mb-2">Platform Improvement</h6>
                                    <p class="small text-muted mb-0">To monitor and analyze usage and trends to improve your experience on our platform.</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 border rounded-3 h-100">
                                    <h6 class="fw-bold mb-2">Legal Obligations</h6>
                                    <p class="small text-muted mb-0">To comply with legal processes and prevent potential fraud or security threats.</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <hr class="my-5 opacity-10">

                    <!-- Section 4: Data Security -->
                    <section class="mb-5">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-primary-light p-3 rounded-3 me-3">
                                <i class="bi bi-shield-lock-fill text-primary-custom fs-4"></i>
                            </div>
                            <h3 class="mb-0">4. Data Security</h3>
                        </div>
                        <p>We have implemented appropriate technical and organizational security measures designed to protect the security of any personal information we process. However, please also remember that we cannot guarantee that the internet itself is 100% secure.</p>
                        <div class="alert alert-light border shadow-none rounded-3 py-3 px-4">
                            <div class="d-flex">
                                <i class="bi bi-shield-check text-success fs-5 me-3"></i>
                                <div>
                                    <h6 class="fw-bold mb-1">Our Security Guarantee</h6>
                                    <p class="small mb-0 text-muted">Passwords are encrypted in our database, and all web traffic is protected via HTTPS/SSL encryption.</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <hr class="my-5 opacity-10">

                    <!-- Section 5: Your Rights -->
                    <section class="mb-5">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-primary-light p-3 rounded-3 me-3">
                                <i class="bi bi-person-check-fill text-primary-custom fs-4"></i>
                            </div>
                            <h3 class="mb-0">5. Your Privacy Rights</h3>
                        </div>
                        <p>Depending on your location, you may have certain rights regarding your personal data:</p>
                        <div class="list-group list-group-flush border-0">
                            <div class="list-group-item bg-transparent border-0 px-0 py-2 d-flex">
                                <i class="bi bi-dot text-primary-custom fs-4 lh-1"></i>
                                <span>The right to access, update or delete the info we have on you.</span>
                            </div>
                            <div class="list-group-item bg-transparent border-0 px-0 py-2 d-flex">
                                <i class="bi bi-dot text-primary-custom fs-4 lh-1"></i>
                                <span>The right of rectification if that information is inaccurate.</span>
                            </div>
                            <div class="list-group-item bg-transparent border-0 px-0 py-2 d-flex">
                                <i class="bi bi-dot text-primary-custom fs-4 lh-1"></i>
                                <span>The right to object to our processing of your personal data.</span>
                            </div>
                        </div>
                    </section>

                    <!-- Section 6: Contact Us -->
                    <section class="mb-0">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-primary-light p-3 rounded-3 me-3">
                                <i class="bi bi-envelope-at-fill text-primary-custom fs-4"></i>
                            </div>
                            <h3 class="mb-0">6. Contact Us</h3>
                        </div>
                        <p>If you have questions or comments about this policy, you may contact us via email at:</p>
                        <div class="d-inline-flex align-items-center p-3 bg-light rounded-3">
                            <i class="bi bi-envelope text-primary-custom me-2"></i>
                            <a href="mailto:privacy@volunteerplatform.com" class="fw-bold text-dark">privacy@volunteerplatform.com</a>
                        </div>
                    </section>

                </div>
            </div>

            <!-- FAQ/Quick Info -->
            <div class="text-center">
                <p class="text-muted">By using VolunteerPlatform, you agree to these terms.</p>
                <a href="/" class="btn btn-outline-secondary rounded-pill px-4">Back to Home</a>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-primary-light {
        background-color: rgba(183, 28, 28, 0.08);
    }
    .tracking-wider {
        letter-spacing: 0.1em;
    }
    .rounded-4 {
        border-radius: 1rem !important;
    }
</style>

