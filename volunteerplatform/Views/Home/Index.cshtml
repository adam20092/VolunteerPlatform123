@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->
<section class="hero-section-premium text-center text-white d-flex align-items-center">
    <div class="container py-5">
        <h1 class="display-3 fw-bold mb-3 hero-text-shadow"><span style="color: var(--primary-color);">Travel differently,</span> <br/> <span class="text-white">connect globally</span></h1>
        <p class="lead mb-5 mx-auto hero-text-shadow" style="max-width: 800px; font-size: 1.5rem;">
            The largest and safest community for cultural exchange, working holiday, volunteering, house & pet sitting in 170 countries.
        </p>
        
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <form asp-controller="Initiatives" asp-action="Index" method="get" class="search-form-hero">
                    <div class="input-group input-group-lg bg-white rounded-pill overflow-hidden p-1 shadow-lg border-0">
                        <input type="text" name="searchString" class="form-control border-0 ps-4 py-3 no-focus" placeholder="Type in a region, country, city ..." aria-label="Search location">
                        <button class="btn btn-primary rounded-pill px-4 me-1 d-flex align-items-center justify-content-center" type="submit" style="height: 52px; width: 60px;">
                            <i class="bi bi-search fs-4"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="d-flex justify-content-center gap-4 mt-5 fw-bold hero-text-shadow">
            <a href="#how-it-works" class="text-white text-decoration-none hover-underline"><i class="bi bi-question-circle me-2"></i>How it works</a>
            <a asp-controller="Account" asp-action="Register" class="text-white text-decoration-none hover-underline"><i class="bi bi-house-door me-2"></i>Join as a Host</a>
        </div>
    </div>
</section>

@if (ViewBag.Recommended != null)
{
    var recs = ViewBag.Recommended as List<volunteerplatform.Models.Initiative>;
    if (recs != null && recs.Any())
    {
        <div class="container mt-n5 position-relative" style="z-index: 10;">
            <div class="bg-white shadow-lg rounded-4 p-4 border-top border-5 border-primary">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold mb-0 text-secondary"><i class="bi bi-magic text-primary me-2"></i>Smart Match: Recommended for You</h3>
                    <a asp-controller="Initiatives" asp-action="Index" class="btn btn-sm btn-outline-primary rounded-pill px-4">See All Missions</a>
                </div>
                <div class="row">
                    @foreach (var item in recs)
                    {
                        <div class="col-md-4 mb-3 mb-md-0">
                            <div class="card h-100 border-0 bg-light p-3 rounded-4 hover-lift">
                                <div class="badge bg-primary rounded-pill mb-3 py-2 px-3 align-self-start small">
                                    <i class="bi bi-star-fill me-1"></i> Matches your skills
                                </div>
                                <h5 class="fw-bold mb-2">@item.Title</h5>
                                <p class="text-muted small mb-3">@item.Location</p>
                                <div class="mt-auto">
                                    <a asp-controller="Initiatives" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary w-100 rounded-pill btn-sm shadow-sm py-2 fw-bold">View Mission</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}

<!-- How It Works Section -->
<div class="container my-5 py-5" id="how-it-works">
    <div class="row text-center mb-5">
        <div class="col-lg-8 mx-auto">
            <h2 class="section-title">How It Works</h2>
            <p class="lead text-muted">Follow these simple steps to start making a real difference in your community.</p>
        </div>
    </div>

    <div class="row g-5">
        <!-- Step 1 -->
        <div class="col-md-6 col-lg-3">
            <div class="how-it-works-step text-center">
                <div class="step-number">1</div>
                <div class="step-icon">
                    <i class="bi bi-person-plus"></i>
                </div>
                <h4 class="fw-bold mb-3">Create Account</h4>
                <p class="text-muted mb-0">
                    Sign up as a <strong>Volunteer</strong> or <strong>Organizer</strong>. Complete your profile to highlight your skills.
                </p>
                <div class="mt-3">
                    <a asp-controller="Account" asp-action="Register" class="text-primary fw-bold small text-decoration-none">Sign Up Now <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>

        <!-- Step 2 -->
        <div class="col-md-6 col-lg-3">
            <div class="how-it-works-step text-center">
                <div class="step-number">2</div>
                <div class="step-icon">
                    <i class="bi bi-geo-alt"></i>
                </div>
                <h4 class="fw-bold mb-3">Find Missions</h4>
                <p class="text-muted mb-0">
                    Use our <strong>Smart Search</strong> to discover volunteering opportunities near you that match your skills.
                </p>
                <div class="mt-3">
                    <a asp-controller="Initiatives" asp-action="Index" class="text-primary fw-bold small text-decoration-none">Explore Map <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>

        <!-- Step 3 -->
        <div class="col-md-6 col-lg-3">
            <div class="how-it-works-step text-center">
                <div class="step-number">3</div>
                <div class="step-icon">
                    <i class="bi bi-check-circle"></i>
                </div>
                <h4 class="fw-bold mb-3">Apply & Join</h4>
                <p class="text-muted mb-0">
                    Click <strong>"Apply Now"</strong> on a mission. Once the organizer approves, you're officially on the team!
                </p>
                <div class="mt-3">
                    <span class="text-muted small">Real-time approval track</span>
                </div>
            </div>
        </div>

        <!-- Step 4 -->
        <div class="col-md-6 col-lg-3">
            <div class="how-it-works-step text-center">
                <div class="step-number">4</div>
                <div class="step-icon">
                    <i class="bi bi-award"></i>
                </div>
                <h4 class="fw-bold mb-3">Track Impact</h4>
                <p class="text-muted mb-0">
                    Earn points, climb the <strong>Leaderboard</strong>, and receive badges as you complete missions.
                </p>
                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Leaderboard" class="text-primary fw-bold small text-decoration-none">View Hall of Fame <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Stats Section -->
<div class="bg-red py-5 mt-5">
    <div class="container">
        <div class="row text-center text-white">
            <div class="col-md-4 mb-4 mb-md-0">
                <div class="display-4 fw-bold">@((ViewBag.Stats?.TotalInitiatives ?? 0))+</div>
                <div>Initiatives</div>
            </div>
            <div class="col-md-4 mb-4 mb-md-0">
                <div class="display-4 fw-bold">@((ViewBag.Stats?.TotalVolunteers ?? 0))+</div>
                <div>Volunteers</div>
            </div>
            <div class="col-md-4 mb-4 mb-md-0">
                <div class="display-4 fw-bold">@((ViewBag.Stats?.CompletedProjects ?? 0))</div>
                <div>Projects Completed</div>
            </div>
        </div>
    </div>
</div>
