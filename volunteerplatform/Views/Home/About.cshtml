@{
    ViewData["Title"] = "About Us";
}

<section class="hero-section-premium text-center text-white d-flex align-items-center" style="background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('https://images.unsplash.com/photo-1593113598332-cd288d649433?ixlib=rb-1.2.1&auto=format&fit=crop&w=1920&q=80'); min-height: 400px;">
    <div class="container">
        <h1 class="display-3 fw-bold mb-3 hero-text-shadow">Our Story</h1>
        <p class="lead mb-0 mx-auto hero-text-shadow" style="max-width: 700px; font-size: 1.5rem;">
            Empowering individuals to create positive change in their communities since 2025.
        </p>
    </div>
</section>

<div class="container my-5 py-5">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <h2 class="section-title text-start mb-4">Our Mission</h2>
            <p class="lead text-muted mb-4">
                At VolunteerPlatform, we believe that everyone has the power to make a difference. Our mission is to bridge the gap between passionate volunteers and organizations in need.
            </p>
            <p class="text-secondary mb-4">
                We provide a seamless digital ecosystem where opportunities are easily discovered, impact is transparently tracked, and communities are strengthened through collective action. Whether it's environmental conservation, social justice, or local community support, we're here to facilitate the connection.
            </p>
            <div class="row g-4 mt-2">
                <div class="col-sm-6">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill text-primary me-3 fs-3"></i>
                        <span class="fw-bold">Verified Partners</span>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill text-primary me-3 fs-3"></i>
                        <span class="fw-bold">Global Impact</span>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill text-primary me-3 fs-3"></i>
                        <span class="fw-bold">Real-time Tracking</span>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill text-primary me-3 fs-3"></i>
                        <span class="fw-bold">Community Focus</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="position-relative">
                <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?ixlib=rb-1.2.1&auto=format&fit=crop&w=1000&q=80" alt="Volunteers working together" class="img-fluid rounded-4 shadow-lg">
                <div class="position-absolute bottom-0 start-0 bg-primary text-white p-4 rounded-4 m-4 d-none d-md-block shadow-lg">
                    <h4 class="mb-0 fw-bold">10,000+</h4>
                    <p class="mb-0 small">Active Volunteers</p>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="bg-light py-5">
    <div class="container my-5">
        <div class="row text-center mb-5">
            <div class="col-lg-8 mx-auto">
                <h2 class="section-title">Our Core Values</h2>
                <p class="lead text-muted">The principles that guide everything we do.</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 p-4 text-center border-0 shadow-sm hover-lift">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-heart"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Empathy</h4>
                    <p class="text-muted mb-0">We approach every connection with understanding and compassion for the needs of our community.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 p-4 text-center border-0 shadow-sm hover-lift">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Integrity</h4>
                    <p class="text-muted mb-0">Transparency and trust are the foundation of our platform, ensuring every donation and hour counts.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 p-4 text-center border-0 shadow-sm hover-lift">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-people"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Collaboration</h4>
                    <p class="text-muted mb-0">We believe in the power of working together to solve the most pressing challenges of our time.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container my-5 py-5">
    <div class="row text-center mb-5">
        <div class="col-lg-8 mx-auto">
            <h2 class="section-title">Our Team</h2>
            <p class="lead text-muted">The passionate individuals behind VolunteerPlatform.</p>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-md-3">
            <div class="text-center">
                <img src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?ixlib=rb-1.2.1&auto=format&fit=crop&w=400&q=80" alt="Sarah Johnson" class="img-fluid rounded-circle mb-3 shadow" style="width: 150px; height: 150px; object-fit: cover;">
                <h5 class="fw-bold mb-1">Sarah Johnson</h5>
                <p class="text-primary small fw-bold">Founder & CEO</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="text-center">
                <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-1.2.1&auto=format&fit=crop&w=400&q=80" alt="David Chen" class="img-fluid rounded-circle mb-3 shadow" style="width: 150px; height: 150px; object-fit: cover;">
                <h5 class="fw-bold mb-1">David Chen</h5>
                <p class="text-primary small fw-bold">Chief Operations</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="text-center">
                <img src="https://images.unsplash.com/photo-1580489944761-15a19d654956?ixlib=rb-1.2.1&auto=format&fit=crop&w=400&q=80" alt="Elena Rodriguez" class="img-fluid rounded-circle mb-3 shadow" style="width: 150px; height: 150px; object-fit: cover;">
                <h5 class="fw-bold mb-1">Elena Rodriguez</h5>
                <p class="text-primary small fw-bold">Community Outreach</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="text-center">
                <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-1.2.1&auto=format&fit=crop&w=400&q=80" alt="Marcus Smith" class="img-fluid rounded-circle mb-3 shadow" style="width: 150px; height: 150px; object-fit: cover;">
                <h5 class="fw-bold mb-1">Marcus Smith</h5>
                <p class="text-primary small fw-bold">Tech Lead</p>
            </div>
        </div>
    </div>
</div>

<section class="bg-red py-5">
    <div class="container text-center text-white py-4">
        <h2 class="fw-bold mb-4">Ready to start your journey?</h2>
        <p class="lead mb-5">Join thousands of volunteers making an impact today.</p>
        <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg rounded-pill px-5 fw-bold text-primary">Join Us Now</a>
    </div>
</section>
