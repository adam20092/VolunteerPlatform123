@model volunteerplatform.Models.Team
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = Model.Name;
    var currentUserId = UserManager.GetUserId(User);
    var isMember = Model.Members?.Any(m => m.MemberId == currentUserId) ?? false;
    var isLeader = Model.LeaderId == currentUserId;
}

<div class="container mt-5">
    <div class="row g-4">
        <!-- Main Content -->
        <div class="col-lg-8">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Teams</a></li>
                    <li class="breadcrumb-item active">@Model.Name</li>
                </ol>
            </nav>

            <div class="d-flex align-items-center mb-4">
                <div class="bg-primary bg-opacity-10 p-4 rounded-4 me-4">
                    <i class="bi bi-people-fill text-primary display-4"></i>
                </div>
                <div>
                    <h1 class="display-5 fw-bold mb-1">@Model.Name</h1>
                    <span class="badge bg-light text-muted border px-3 py-2 rounded-pill">Created on @Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 mb-5">
                <div class="card-body p-4 p-lg-5">
                    <h4 class="fw-bold mb-4">About the Team</h4>
                    <p class="lead text-secondary">@Model.Description</p>
                </div>
            </div>

            <h4 class="fw-bold mb-4"><i class="bi bi-person-check me-2 text-primary"></i>Team Members (@(Model.Members?.Count ?? 0))</h4>
            <div class="row g-3 mb-5">
                @if (Model.Members != null)
                {
                    foreach (var member in Model.Members)
                    {
                        <div class="col-md-6">
                            <div class="d-flex align-items-center p-3 border rounded-3 bg-white shadow-xs">
                                <div class="rounded-circle bg-secondary text-white d-flex justify-content-center align-items-center me-3" style="width: 45px; height: 45px;">
                                    @member.Member.FullName?.Substring(0,1)
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">@member.Member.FullName</h6>
                                    <small class="text-muted">@member.Role</small>
                                </div>
                                @if (member.MemberId == Model.LeaderId)
                                {
                                    <span class="badge bg-warning text-dark ms-auto rounded-pill small">Leader</span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 2rem;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Team Management</h5>
                    
                    @if (User.Identity!.IsAuthenticated)
                    {
                        @if (isLeader)
                        {
                            <div class="alert alert-info rounded-3 small">
                                <i class="bi bi-info-circle me-1"></i> You are the leader of this team.
                            </div>
                        }
                        else if (isMember)
                        {
                            <form asp-action="Leave" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="btn btn-outline-danger w-100 py-3 rounded-pill fw-bold" onclick="return confirm('Are you sure you want to leave this team?')">
                                    <i class="bi bi-box-arrow-right me-2"></i>Leave Team
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Join" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow">
                                    <i class="bi bi-person-plus me-2"></i>Join Team
                                </button>
                            </form>
                        }
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary w-100 py-3 rounded-pill fw-bold">Login to Join</a>
                    }

                    <hr class="my-4" />

                    <h6 class="fw-bold mb-3">Recent Initiatives</h6>
                    @if (Model.Initiatives != null && Model.Initiatives.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var ini in Model.Initiatives.Take(3))
                            {
                                <a asp-controller="Initiatives" asp-action="Details" asp-route-id="@ini.Id" class="list-group-item list-group-item-action border-0 px-0 mb-2">
                                    <div class="fw-bold text-primary">@ini.Title</div>
                                    <small class="text-muted"><i class="bi bi-calendar-event me-1"></i> @ini.DateAndTime.ToString("MMM dd")</small>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="small text-muted mb-0">No active initiatives assigned.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
