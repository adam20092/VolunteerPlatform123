@using Microsoft.AspNetCore.Identity
@using volunteerplatform.Models
@inject UserManager<ApplicationUser> UserManager
@model IEnumerable<volunteerplatform.Models.Initiative>

@{
    ViewData["Title"] = "Initiatives";
    var currentUser = await UserManager.GetUserAsync(User);
}

<div class="container mt-5">
    <div class="row align-items-center mb-4 g-3">
        <div class="col-12 col-lg-7">
            <h1 class="display-5 fw-bold text-secondary mb-0">Volunteering Opportunities</h1>
        </div>
        <div class="col-12 col-lg-5 text-lg-end">
            @if (User.IsInRole("Organizer") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
            {
                <a asp-action="Create" class="btn btn-primary shadow-sm w-100 w-lg-auto"><i class="bi bi-plus-lg me-2"></i>Create New Mission</a>
            }
        </div>
    </div>

    <div class="row mb-5 justify-content-center">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 p-4 p-lg-5 bg-light">
                <form asp-action="Index" method="get" class="row g-3">
                    <div class="col-12 col-lg-5">
                        <label class="form-label fw-bold small text-muted">Search Keywords</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                            <input type="text" name="searchString" class="form-control border-start-0" placeholder="Keywords..." value="@ViewData["CurrentFilter"]">
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label fw-bold small text-muted">Category</label>
                        <select name="category" class="form-select">
                            <option value="">All Categories</option>
                            @foreach (var cat in ViewBag.Categories as List<string>)
                            {
                                <option value="@cat" selected="@(ViewData["CurrentCategory"]?.ToString() == cat)">@cat</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label fw-bold small text-muted">Region</label>
                        <select name="region" class="form-select">
                            <option value="">All Regions</option>
                            @foreach (var reg in ViewBag.Regions as List<string>)
                            {
                                <option value="@reg" selected="@(ViewData["CurrentRegion"]?.ToString() == reg)">@reg</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-lg-1 d-flex align-items-end">
                        <button class="btn btn-primary w-100 py-2 h-100" type="submit">
                            <i class="bi bi-funnel"></i>
                        </button>
                    </div>
                </form>
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"] as string) || !string.IsNullOrEmpty(ViewData["CurrentCategory"] as string) || !string.IsNullOrEmpty(ViewData["CurrentRegion"] as string))
                {
                    <div class="mt-3 text-center">
                        <a asp-action="Index" class="text-decoration-none small text-muted"><i class="bi bi-x-circle me-1"></i> Reset filters</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12 col-md-6 col-lg-4 mb-2">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                             <div>
                                <span class="badge bg-danger rounded-pill">@item.Status</span>
                                @if (item.TargetAmount > 0)
                                {
                                    <span class="badge bg-success rounded-pill ml-1"><i class="bi bi-heart-fill me-1"></i>Fundraising</span>
                                }
                             </div>
                             <small class="text-muted"><i class="bi bi-calendar-event me-1"></i> @item.DateAndTime.ToString("MMM dd, yyyy")</small>
                        </div>
                       
                        <h5 class="card-title fw-bold my-3">@item.Title</h5>
                        <p class="card-text text-muted mb-3">@item.Description?.Substring(0, Math.Min(item.Description.Length, 100))...</p>
                        
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-geo-alt text-primary me-2"></i>
                            <span class="small">@item.Location</span>
                        </div>

                        @{
                            var cardSkills = (item.RequiredSkills ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                        }
                        @if (cardSkills.Any())
                        {
                            <div class="mb-3 d-flex flex-wrap gap-1">
                                @foreach (var sk in cardSkills.Take(4))
                                {
                                    <span class="badge bg-light text-secondary border rounded-pill small">@sk</span>
                                }
                                @if (cardSkills.Length > 4)
                                {
                                    <span class="badge bg-light text-muted border rounded-pill small">+@(cardSkills.Length - 4) more</span>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="mb-3"><span class="badge bg-light text-muted border rounded-pill small">No skills required</span></div>
                        }

                        <div class="d-flex align-items-center text-muted small mb-4">
                             @{
                                 var approvedCount = item.Enrolments?.Count(e => e.Status == volunteerplatform.Models.EnrolmentStatus.Approved) ?? 0;
                             }
                             <i class="bi bi-people me-2"></i> Approved: @approvedCount/@item.RequiredVolunteers
                        </div>

                    </div>
                    <div class="card-footer bg-white border-0 pb-4 pt-0">
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary flex-grow-1 rounded-pill">View Details</a>
                            @if (currentUser != null && (item.OrganizerId == currentUser.Id || User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger rounded-pill"><i class="bi bi-trash"></i></a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
