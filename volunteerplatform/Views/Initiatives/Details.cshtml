@using Microsoft.AspNetCore.Identity
@using volunteerplatform.Models
@inject UserManager<ApplicationUser> UserManager
@model volunteerplatform.Models.Initiative

@{
    ViewData["Title"] = Model.Title ?? "Details";
    var currentUser = await UserManager.GetUserAsync(User);
    var requiredSkills = (Model.RequiredSkills ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var volunteerSkills = (currentUser?.Skills ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var matchedSkills = requiredSkills.Where(rs => volunteerSkills.Any(vs => vs.Equals(rs, StringComparison.OrdinalIgnoreCase))).ToList();
    bool isVolunteer = User.IsInRole("Volunteer");
    bool hasSkillMatch = !requiredSkills.Any() || matchedSkills.Any();
}

<div class="container mt-5">
    
    <div class="row">
        <div class="col-lg-8">
            <h1 class="display-5 fw-bold mb-3">@Model.Title</h1>
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                 <div class="d-flex gap-3">
                    <span class="badge bg-primary px-3 py-2">@Model.Status</span>
                    <span class="text-muted"><i class="bi bi-clock me-1"></i> @Model.DateAndTime.ToString("f")</span>
                 </div>
                 @if(Model.Organizer != null) {
                    <div class="d-flex align-items-center">
                         <div class="rounded-circle bg-secondary text-white d-flex justify-content-center align-items-center me-2" style="width: 40px; height: 40px;">
                             @Model.Organizer.FullName?.Substring(0,1)
                         </div>
                         <div>
                             <small class="d-block text-muted line-height-1">Organized by</small>
                             <span class="fw-bold">@Model.Organizer.FullName</span>
                         </div>
                    </div>
                 }
            </div>

            <img src="https://images.unsplash.com/photo-1593113598332-cd288d649433?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80" 
                 class="img-fluid rounded-3 shadow-sm mb-5 w-100" alt="Initiative Cover" style="max-height: 400px; object-fit: cover;">


            <h4 class="fw-bold mb-3">About the Mission</h4>
            <p class="lead mb-5 text-secondary">
                @Model.Description
            </p>

            <h4 class="fw-bold mb-3">Requirements</h4>
            <div class="mb-3">
                <i class="bi bi-people me-2 text-primary"></i>
                <strong>@Model.RequiredVolunteers</strong> Volunteers needed
            </div>
            <div class="mb-5">
                <i class="bi bi-stars me-2 text-primary"></i>
                <strong class="me-2">Required Skills:</strong>
                @if (!requiredSkills.Any())
                {
                    <span class="badge bg-secondary rounded-pill">No special skills required</span>
                }
                else
                {
                    foreach (var skill in requiredSkills)
                    {
                        bool matched = isVolunteer && matchedSkills.Any(m => m.Equals(skill, StringComparison.OrdinalIgnoreCase));
                        <span class="badge rounded-pill me-1 mb-1 @(matched ? "bg-success" : "bg-primary")">
                            @if (matched) { <i class="bi bi-check-lg me-1"></i> }
                            @skill
                        </span>
                    }
                }
            </div>

            @if (isVolunteer && requiredSkills.Any())
            {
                <div class="alert @(hasSkillMatch ? "alert-success" : "alert-warning") d-flex align-items-center rounded-3 mb-5" role="alert">
                    <i class="bi @(hasSkillMatch ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") fs-4 me-3"></i>
                    <div>
                        @if (hasSkillMatch)
                        {
                            <strong>You match @matchedSkills.Count of @requiredSkills.Length required skills!</strong>
                            <div class="small mt-1">Matched: @string.Join(", ", matchedSkills)</div>
                        }
                        else
                        {
                            <strong>Your skills don't fully match this mission's requirements.</strong>
                            <div class="small mt-1">Required: @string.Join(", ", requiredSkills) — you must match at least one to apply!</div>
                        }
                    </div>
                </div>
            }

        </div>
        
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 sticky-top" style="top: 100px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Join this Mission</h5>
                    
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-geo-alt fs-4 text-primary me-3"></i>
                        <div>
                            <small class="d-block text-muted">Location</small>
                            <strong>@Model.Location</strong>
                        </div>
                    </div>

                    @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                    {
                        <div id="map-detail" style="height: 200px; border-radius: 8px;" class="mb-4 border"></div>
                        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
                        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
                        <script>
                             document.addEventListener('DOMContentLoaded', function() {
                                var lat = @Model.Latitude;
                                var lng = @Model.Longitude;
                                var map = L.map('map-detail').setView([lat, lng], 14);
                                L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                                    maxZoom: 19,
                                    attribution: 'OSM'
                                }).addTo(map);
                                L.marker([lat, lng]).addTo(map);
                            });
                        </script>
                    }

                     <div class="d-flex align-items-center mb-4">
                        <i class="bi bi-calendar-check fs-4 text-primary me-3"></i>
                        <div>
                            <small class="d-block text-muted">Date</small>
                            <strong>@Model.DateAndTime.ToString("MMM dd, yyyy")</strong>
                        </div>
                    </div>



                    @if(User.Identity.IsAuthenticated)
                    {
                         @if(User.IsInRole("Volunteer"))
                         {
                            @if(TempData["Success"] != null)
                            {
                                <div class="alert alert-success">@TempData["Success"]</div>
                            }
                            @if(TempData["Message"] != null)
                            {
                                <div class="alert alert-warning">@TempData["Message"]</div>
                            }
                            @if(TempData["Error"] != null)
                            {
                                <div class="alert alert-danger fw-bold"><i class="bi bi-x-circle-fill me-2"></i>@TempData["Error"]</div>
                            }

                             <form asp-controller="Enrolments" asp-action="Apply" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm mb-3">Apply Now</button>
                             </form>
                         }
                         else if (User.IsInRole("Organizer") && Model.OrganizerId == (await UserManager.GetUserAsync(User))?.Id || User.IsInRole("Admin"))
                         {
                             <a asp-controller="Enrolments" asp-action="Manage" asp-route-id="@Model.Id" class="btn btn-warning btn-lg w-100 rounded-pill shadow-sm mb-3">Manage Candidates</a>
                             <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-lg w-100 rounded-pill shadow-sm mb-3">Delete Mission</a>
                         }
                    }
                    else
                    {
                         <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm mb-3">Login to Apply</a>
                    }
                    
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 rounded-pill">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>
