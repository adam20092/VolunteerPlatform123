@using Microsoft.AspNetCore.Identity
@using volunteerplatform.Models
@inject UserManager<ApplicationUser> UserManager
@model volunteerplatform.Models.Initiative

@{
    ViewData["Title"] = Model.Title ?? "Details";
    var currentUser = await UserManager.GetUserAsync(User);
    var requiredSkills = (Model.RequiredSkills ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var volunteerSkills = (currentUser?.Skills ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var matchedSkills = requiredSkills.Where(rs => volunteerSkills.Any(vs => vs.Equals(rs, StringComparison.OrdinalIgnoreCase))).ToList();
    bool isVolunteer = User.IsInRole("Volunteer");
    bool hasSkillMatch = !requiredSkills.Any() || matchedSkills.Any();
}

            </div>
            
            <hr class="my-5" />

            @* Task Tracking Section *@
            <h4 class="fw-bold mb-4"><i class="bi bi-list-task me-2 text-primary"></i>Mission Tasks</h4>

            @{
                bool isOrganizerOrAdmin = (Model.OrganizerId == currentUser?.Id) || User.IsInRole("Admin") || User.IsInRole("SuperAdmin");
                bool isApproved = Model.Enrolments?.Any(e => e.VolunteerId == currentUser?.Id && e.Status == volunteerplatform.Models.EnrolmentStatus.Approved) ?? false;
            }

            @if (isOrganizerOrAdmin)
            {
                <form asp-controller="Tasks" asp-action="Create" method="post" class="mb-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="initiativeId" value="@Model.Id" />
                    <div class="input-group">
                        <input type="text" name="title" class="form-control" placeholder="New Task (e.g. Water bottles)" required />
                        <button class="btn btn-primary" type="submit">Add Task</button>
                    </div>
                </form>
            }

            <div class="list-group list-group-flush shadow-sm rounded-3 mb-5 border">
                @if (Model.Tasks == null || !Model.Tasks.Any())
                {
                    <div class="list-group-item text-center py-4 text-muted">
                        No tasks added for this mission yet.
                    </div>
                }
                else
                {
                    foreach (var task in Model.Tasks)
                    {
                        <div class="list-group-item d-flex align-items-center justify-content-between py-3">
                            <div class="d-flex align-items-center">
                                <div class="form-check me-3">
                                    <input class="form-check-input task-toggle" type="checkbox" 
                                           data-id="@task.Id" 
                                           @(task.IsCompleted ? "checked" : "") 
                                           @(!isOrganizerOrAdmin && !isApproved ? "disabled" : "") />
                                </div>
                                <div class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "")" id="task-title-@task.Id">
                                    <span class="fw-bold">@task.Title</span>
                                    @if (task.IsCompleted && task.CompletedAt.HasValue)
                                    {
                                        <div class="small text-muted">Completed on @task.CompletedAt.Value.ToString("g")</div>
                                    }
                                </div>
                            </div>
                            @if (isOrganizerOrAdmin)
                            {
                                <form asp-controller="Tasks" asp-action="Delete" asp-route-id="@task.Id" method="post" class="ms-3">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link text-danger p-0" onclick="return confirm('Delete task?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    }
                }
            </div>
            
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    const checkboxes = document.querySelectorAll('.task-toggle');
                    checkboxes.forEach(cb => {
                        cb.addEventListener('change', async function() {
                            const taskId = this.dataset.id;
                            const titleEl = document.getElementById('task-title-' + taskId);
                            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                            try {
                                const response = await fetch('/Tasks/Toggle/' + taskId, {
                                    method: 'POST',
                                    headers: {
                                        'X-Requested-With': 'XMLHttpRequest',
                                        'RequestVerificationToken': token
                                    }
                                });

                                if (response.ok) {
                                    const result = await response.json();
                                    if(result.isCompleted) {
                                        titleEl.classList.add('text-decoration-line-through', 'text-muted');
                                    } else {
                                        titleEl.classList.remove('text-decoration-line-through', 'text-muted');
                                    }
                                } else {
                                    this.checked = !this.checked; // Revert
                                    alert('Error updating task status.');
                                }
                            } catch (err) {
                                this.checked = !this.checked;
                                alert('Connection error.');
                            }
                        });
                    });
                });
            </script>
        </div>
        
        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="card shadow-sm border-0 sticky-top" style="top: 100px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Join this Mission</h5>
                    
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-geo-alt fs-4 text-primary me-3"></i>
                        <div>
                            <small class="d-block text-muted">Location</small>
                            <strong>@Model.Location</strong>
                        </div>
                    </div>

                    @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                    {
                        <div id="map-detail" style="height: 200px; border-radius: 8px;" class="mb-4 border"></div>
                        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
                        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
                        <script>
                             document.addEventListener('DOMContentLoaded', function() {
                                var lat = @Model.Latitude;
                                var lng = @Model.Longitude;
                                var map = L.map('map-detail').setView([lat, lng], 14);
                                L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                                    maxZoom: 19,
                                    attribution: 'OSM'
                                }).addTo(map);
                                
                                // Apply dark filter if needed
                                if(document.documentElement.getAttribute('data-theme') === 'dark') {
                                    document.querySelector('#map-detail').classList.add('leaflet-dark');
                                }

                                L.marker([lat, lng]).addTo(map);
                            });
                        </script>
                    }

                     <div class="d-flex align-items-center mb-4">
                        <i class="bi bi-calendar-check fs-4 text-primary me-3"></i>
                        <div>
                            <small class="d-block text-muted">Date</small>
                            <strong>@Model.DateAndTime.ToString("MMM dd, yyyy")</strong>
                        </div>
                    </div>



                    @if(User.Identity?.IsAuthenticated == true)
                    {
                         @if(User.IsInRole("Volunteer"))
                         {
                            @if(TempData["Success"] != null)
                            {
                                <div class="alert alert-success">@TempData["Success"]</div>
                            }
                            @if(TempData["Message"] != null)
                            {
                                <div class="alert alert-warning">@TempData["Message"]</div>
                            }
                            @if(TempData["Error"] != null)
                            {
                                <div class="alert alert-danger fw-bold"><i class="bi bi-x-circle-fill me-2"></i>@TempData["Error"]</div>
                            }

                            bool hasApplied = Model.Enrolments != null && Model.Enrolments.Any(e => e.VolunteerId == currentUser?.Id);

                            if (Model.Status != volunteerplatform.Models.MissionStatus.Active)
                            {
                                <div class="alert alert-secondary text-center fw-bold">This mission has ended.</div>
                            }
                            else if (hasApplied)
                            {
                                <button type="button" class="btn btn-success btn-lg w-100 rounded-pill shadow-sm mb-3" disabled>
                                    <i class="bi bi-check-circle-fill me-2"></i>You applied for this mission
                                </button>
                            }
                            else
                            {
                                <form asp-controller="Enrolments" asp-action="Apply" asp-route-id="@Model.Id" method="post">
                                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm mb-3">Apply Now</button>
                                </form>
                            }
                         }
                         else if (User.IsInRole("Organizer") && Model.OrganizerId == currentUser?.Id || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                         {
                             <a asp-controller="Enrolments" asp-action="Manage" asp-route-id="@Model.Id" class="btn btn-warning btn-lg w-100 rounded-pill shadow-sm mb-3">Manage Candidates</a>
                             <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-lg w-100 rounded-pill shadow-sm mb-3">Delete Mission</a>
                         }
                    }
                    else
                    {
                         <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm mb-3">Login to Apply</a>
                    }
                    
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 rounded-pill">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>
