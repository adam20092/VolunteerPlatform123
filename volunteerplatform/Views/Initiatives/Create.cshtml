@model volunteerplatform.Models.Initiative

@{
    ViewData["Title"] = "Create Initiative";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header-custom text-white text-center py-4">
                    <h2 class="mb-0 h3">Create New Mission</h2>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold small text-uppercase text-muted">Mission Title</label>
                            <input asp-for="Title" class="form-control form-control-lg" placeholder="e.g. Tree Planting in Central Park" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold small text-uppercase text-muted">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe what volunteers will be doing..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Category" class="form-label fw-bold small text-uppercase text-muted">Category</label>
                                <select asp-for="Category" class="form-select">
                                    <option value="">Select Category</option>
                                    <option value="Environment">Environment</option>
                                    <option value="Education">Education</option>
                                    <option value="Health">Health</option>
                                    <option value="Social">Social</option>
                                    <option value="Animal Welfare">Animal Welfare</option>
                                    <option value="Other">Other</option>
                                </select>
                                <span asp-validation-for="Category" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="Region" class="form-label fw-bold small text-uppercase text-muted">Region (District)</label>
                                <select asp-for="Region" class="form-select">
                                    <option value="">Select Region</option>
                                    <option value="Sofia">Sofia</option>
                                    <option value="Plovdiv">Plovdiv</option>
                                    <option value="Varna">Varna</option>
                                    <option value="Burgas">Burgas</option>
                                    <option value="Ruse">Ruse</option>
                                    <option value="Stara Zagora">Stara Zagora</option>
                                    <option value="Other">Other</option>
                                </select>
                                <span asp-validation-for="Region" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Location" class="form-label fw-bold small text-uppercase text-muted">Location</label>
                                <div class="input-group mb-2">
                                    <span class="input-group-text bg-light"><i class="bi bi-geo-alt"></i></span>
                                    <input asp-for="Location" id="Location" class="form-control" placeholder="City, Address" />
                                    <button class="btn btn-primary px-3 fw-bold" type="button" id="searchLocationBtn">
                                        <i class="bi bi-search me-1"></i> Search
                                    </button>
                                </div>
                                <span asp-validation-for="Location" class="text-danger"></span>
                                
                                <div id="map" style="height: 300px; border-radius: 8px;" class="mb-2 border"></div>
                                <small class="text-muted"><i class="bi bi-info-circle"></i> Click on the map to pin the exact location.</small>
                                
                                <input type="hidden" asp-for="Latitude" id="Latitude" />
                                <input type="hidden" asp-for="Longitude" id="Longitude" />
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="DateAndTime" class="form-label fw-bold small text-uppercase text-muted">Date & Time</label>
                                <input asp-for="DateAndTime" class="form-control" />
                                <span asp-validation-for="DateAndTime" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="RequiredVolunteers" class="form-label fw-bold small text-uppercase text-muted">Volunteers Needed</label>
                                <input asp-for="RequiredVolunteers" class="form-control" min="1" placeholder="10" />
                                <span asp-validation-for="RequiredVolunteers" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold small text-uppercase text-muted">Required Skills</label>
                                <input type="hidden" asp-for="RequiredSkills" id="RequiredSkills" />
                                <div class="border rounded-3 p-3 bg-light skill-picker">
                                    @foreach (var skill in new[] { "Teaching", "IT", "Cooking", "First Aid", "Driving", "Social Media", "Art", "Languages", "Construction", "Animal Care", "Communication", "Organization", "Events", "Design" })
                                    {
                                        <div class="form-check form-check-inline skill-check-item">
                                            <input class="form-check-input skill-cb" type="checkbox" value="@skill" id="skill_@skill.Replace(" ", "_")" />
                                            <label class="form-check-label small" for="skill_@skill.Replace(" ", "_")">@skill</label>
                                        </div>
                                    }
                                </div>
                                <small class="text-muted mt-1 d-block">Select all skills needed. Leave empty for "No skills required".</small>
                                <span asp-validation-for="RequiredSkills" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-4">
                            <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow">Publish Mission</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // ── Map ──────────────────────────────────────────────────────────────
            var map = L.map('map').setView([42.6977, 23.3219], 13); // Default to Sofia

            L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            var marker;

            map.on('click', function(e) {
                if(marker) {
                    map.removeLayer(marker);
                }
                marker = L.marker(e.latlng).addTo(map);
                document.getElementById('Latitude').value = e.latlng.lat;
                document.getElementById('Longitude').value = e.latlng.lng;
            });

            // ── Location Search via Geocoding ────────────────────────────────────
            var searchBtn = document.getElementById('searchLocationBtn');
            var locInput = document.getElementById('Location');

            function geocodeLocation() {
                var query = locInput.value.trim();
                if (!query) return;

                // Add country specific search if needed, but standard query works well
                fetch('https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(query))
                    .then(response => response.json())
                    .then(data => {
                        if (data && data.length > 0) {
                            var lat = parseFloat(data[0].lat);
                            var lon = parseFloat(data[0].lon);
                            
                            if (marker) {
                                map.removeLayer(marker);
                            }
                            marker = L.marker([lat, lon]).addTo(map);
                            map.setView([lat, lon], 14); // Zoom into the place
                            
                            document.getElementById('Latitude').value = lat;
                            document.getElementById('Longitude').value = lon;
                        } else {
                            alert('Location not found on the map. Please try a different search term.');
                        }
                    })
                    .catch(err => console.error('Geocoding error:', err));
            }

            searchBtn.addEventListener('click', geocodeLocation);
            
            // Allow pressing Enter key to search instead of submitting form
            locInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    geocodeLocation();
                }
            });

            // ── Skills aggregation ───────────────────────────────────────────────
            function updateSkills() {
                var checked = Array.from(document.querySelectorAll('.skill-cb:checked'))
                                   .map(cb => cb.value);
                document.getElementById('RequiredSkills').value = checked.join(', ');
            }
            document.querySelectorAll('.skill-cb').forEach(cb => {
                cb.addEventListener('change', updateSkills);
            });

            // Pre-populate checkboxes if editing (value already set in hidden field)
            var existing = document.getElementById('RequiredSkills').value;
            if (existing) {
                existing.split(',').map(s => s.trim()).forEach(function(skill) {
                    var cb = document.querySelector('.skill-cb[value="' + skill + '"]');
                    if (cb) cb.checked = true;
                });
            }
        });
    </script>
    <style>
        .skill-picker { max-height: 180px; overflow-y: auto; }
        .skill-check-item { margin: 4px 6px; }
    </style>
}
