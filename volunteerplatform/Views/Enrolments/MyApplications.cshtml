@model IEnumerable<volunteerplatform.Models.Enrolment>

@{
    ViewData["Title"] = "My Applications";
}

<div class="container mt-5">
    <h2 class="mb-4 fw-bold">My Applications</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">You haven't applied to any missions yet. <a asp-controller="Initiatives" asp-action="Index">Find one now!</a></div>
    }
    else
    {
        <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title fw-bold">@item.Initiative.Title</h5>
                            <span class="badge @(item.Status == volunteerplatform.Models.EnrolmentStatus.Approved ? "bg-success" : 
                                                 item.Status == volunteerplatform.Models.EnrolmentStatus.Rejected ? "bg-danger" : "bg-warning")">
                                @item.Status
                            </span>
                        </div>
                         <p class="text-muted mb-2">Applied on: @item.AppliedOn.ToString("g")</p>
                         <div class="mt-3 d-flex gap-2">
                            <a asp-controller="Initiatives" asp-action="Details" asp-route-id="@item.InitiativeId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                <i class="bi bi-info-circle me-1"></i> Details
                            </a>
                            @if (item.Status == volunteerplatform.Models.EnrolmentStatus.Approved && item.Initiative.Status == volunteerplatform.Models.MissionStatus.Finished)
                            {
                                <a asp-action="Certificate" asp-route-id="@item.Id" class="btn btn-sm btn-success rounded-pill px-3">
                                    <i class="bi bi-patch-check me-1"></i> Certificate
                                </a>
                            }
                         </div>
                    </div>
                </div>
            </div>
        }
        </div>
    }
</div>
