@model volunteerplatform.Models.Enrolment
@{
    Layout = "_Layout";
    ViewData["Title"] = "Mission Achievement Certificate";
}

<div class="container my-5 pb-5">
    <div class="text-center mb-4 no-print">
        <button onclick="window.print()" class="btn btn-primary btn-lg rounded-pill shadow me-2">
            <i class="bi bi-printer me-2"></i> Print Certificate
        </button>
        <a asp-action="DownloadCertificate" asp-route-id="@Model.Id" class="btn btn-outline-success btn-lg rounded-pill shadow">
            <i class="bi bi-download me-2"></i> Download File
        </a>
        <p class="text-muted small mt-2">Adjust your printer settings to "Background Graphics: On" for the best look.</p>
    </div>

    <!-- The Certificate Card -->
    <div class="certificate-container shadow-lg mx-auto p-1 bg-white border border-5 border-double border-primary" style="max-width: 900px; position: relative;">
        
        <div class="certificate-inner p-5 text-center" style="border: 2px solid #b71c1c; margin: 10px; background: #fffcfc;">
            
            <div class="certificate-header mb-4">
                <i class="bi bi-award text-primary display-1"></i>
                <h1 class="display-3 fw-bold text-secondary mt-3" style="font-family: 'Times New Roman', serif;">CERTIFICATE</h1>
                <h5 class="text-uppercase tracking-widest text-muted">of achievement</h5>
            </div>

            <div class="certificate-content my-5">
                <p class="lead text-muted">This is to certify that</p>
                <h2 class="display-5 fw-bold text-primary text-decoration-underline py-2">@Model.Volunteer.FullName</h2>
                <p class="lead text-muted mt-3">has successfully completed the volunteer mission:</p>
                <h3 class="fw-bold text-secondary italic">"@Model.Initiative.Title"</h3>
                <p class="text-muted">held on @Model.Initiative.DateAndTime.ToString("MMMM dd, yyyy")</p>
            </div>

            <div class="certificate-footer row mt-5 pt-3">
                <div class="col-6">
                    <div class="border-top pt-2 mx-5">
                        <p class="fw-bold mb-0">@Model.Initiative.Organizer?.FullName</p>
                        <small class="text-muted">Project Coordinator</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="border-top pt-2 mx-5">
                        <p class="fw-bold mb-0">@DateTime.Now.ToString("dd/MM/yyyy")</p>
                        <small class="text-muted">Date of Issue</small>
                    </div>
                </div>
            </div>

            <!-- Authentic Stamp/Seal -->
            <div class="certificate-seal" style="position: absolute; bottom: 40px; right: 40px; opacity: 0.1;">
                <i class="bi bi-shield-check display-1"></i>
            </div>
            
            <div class="mt-5 pt-4">
                <small class="text-muted font-monospace">Verification Code: @Model.CertificateCode</small>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        .no-print { display: none !important; }
        body { background: white !important; }
        .container { width: 100% !important; max-width: 100% !important; padding: 0 !important; margin: 0 !important; }
        .certificate-container { border: none !important; box-shadow: none !important; margin: 0 !important; }
    }
    
    .tracking-widest { letter-spacing: 0.2em; }
    .italic { font-style: italic; }
</style>
