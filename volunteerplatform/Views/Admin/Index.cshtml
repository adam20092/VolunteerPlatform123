@model volunteerplatform.Models.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">
    <h1 class="display-6 fw-bold mb-4">Admin Dashboard</h1>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary mb-3 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-people-fill me-2"></i>Volunteers</h5>
                    <p class="card-text display-4">@Model.TotalVolunteers</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success mb-3 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-building me-2"></i>Organizers</h5>
                    <p class="card-text display-4">@Model.TotalOrganizers</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info mb-3 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-flag-fill me-2"></i>Missions</h5>
                    <p class="card-text display-4">@Model.TotalMission</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning mb-3 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title text-dark"><i class="bi bi-check-circle-fill me-2"></i>Completed</h5>
                    <p class="card-text display-4 text-dark">@Model.CompletedMissions</p>
                </div>
            </div>
        </div>
    </div>

    @* Pending Requests Alert *@
    @if (Model.PendingRequests > 0)
    {
        <div class="alert alert-warning d-flex align-items-center justify-content-between mb-4" role="alert">
            <div>
                <i class="bi bi-clock-fill me-2"></i>
                <strong>@Model.PendingRequests</strong> volunteer request(s) are waiting for review.
            </div>
            <a asp-action="Requests" class="btn btn-warning btn-sm">Review Now</a>
        </div>
    }

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-people me-2"></i>Recent Users</span>
                    <a asp-action="Requests" class="btn btn-primary btn-sm">
                        <i class="bi bi-clipboard-check me-1"></i>Manage Volunteer Requests
                        @if (Model.PendingRequests > 0)
                        {
                            <span class="badge bg-danger ms-1">@Model.PendingRequests</span>
                        }
                    </a>
                </div>
                <div class="card-body">
                     <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Full Name</th>
                                <th>Id</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.RecentUsers)
                            {
                                <tr>
                                    <td>@user.Email</td>
                                    <td>@user.FullName</td>
                                    <td><small class="text-muted">@user.Id</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a asp-action="Users" class="btn btn-outline-primary w-100">View All Users</a>
                </div>
            </div>
        </div>
    </div>
</div>
