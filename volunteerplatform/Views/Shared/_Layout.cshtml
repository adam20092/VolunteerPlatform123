                            </div>
                        </label>
                    </div>
                    <div id="google_translate_element" style="display:none;"></div>
                    <partial name="_LoginPartial" />
                    <div class="custom-language-selector dropdown ms-3 d-flex align-items-center">
                        <button class="btn btn-light btn-sm dropdown-toggle rounded-pill px-2 py-1 shadow-sm border border-secondary border-opacity-25" type="button" id="languageDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="font-weight: 600; font-size: 0.85rem;">
                            <i class="bi bi-globe text-primary me-1"></i> <span id="currentLangText" class="notranslate">EN</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="languageDropdown" style="font-size: 0.85rem; min-width: auto; padding: 0.5rem;">
                            <li><a class="dropdown-item fw-bold px-3 py-1 rounded" href="#" onclick="changeLanguage('en', 'EN'); return false;"><span class="me-2">🇬🇧</span> English</a></li>
                            <li><a class="dropdown-item fw-bold px-3 py-1 rounded" href="#" onclick="changeLanguage('bg', 'BG'); return false;"><span class="me-2">🇧🇬</span> Български</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
