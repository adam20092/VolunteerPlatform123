                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">HOME</a>
                        </li>
                         <li class="nav-item">
                             <a class="nav-link" asp-area="" asp-controller="Initiatives" asp-action="Index">INITIATIVES</a>
                         </li>
                         <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Initiatives" asp-action="Map">MAP</a>
                         </li>
                         <li class="nav-item">
                             <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Leaderboard">LEADERBOARD</a>
                         </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">ABOUT US</a>
