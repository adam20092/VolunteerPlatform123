                        <li><a asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h5 class="text-white">Connect</h5>
                     <p class="small text-white-50">contact us on this number 0899993591 or akasabi2009@gmail.com</p>
                </div>
            </div>
            <hr style="border-color: rgba(255,255,255,0.1);" />
            <p class="mb-0">&copy; 2025 VolunteerPlatform. All rights reserved. | <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Theme Switcher Logic
        const toggleSwitch = document.querySelector('.theme-switch input[type="checkbox"]');
        const currentTheme = localStorage.getItem('theme');

        if (currentTheme) {
            document.documentElement.setAttribute('data-theme', currentTheme);
            if (currentTheme === 'dark') {
                toggleSwitch.checked = true;
            }
        }

        function switchTheme(e) {
            if (e.target.checked) {
                document.documentElement.setAttribute('data-theme', 'dark');
                localStorage.setItem('theme', 'dark');
            } else {
                document.documentElement.setAttribute('data-theme', 'light');
                localStorage.setItem('theme', 'light');
            }
        }

        toggleSwitch.addEventListener('change', switchTheme, false);

        // Reveal animations on scroll
        function reveal() {
            var reveals = document.querySelectorAll(".reveal");
            for (var i = 0; i < reveals.length; i++) {
                var windowHeight = window.innerHeight;
                var elementTop = reveals[i].getBoundingClientRect().top;
                var elementVisible = 150;
                if (elementTop < windowHeight - elementVisible) {
                    reveals[i].classList.add("active");
                }
            }
        }

        window.addEventListener("scroll", reveal);
        // Initial check
        document.addEventListener("DOMContentLoaded", reveal);
    </script>
    <script type="text/javascript">
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'en',
                includedLanguages: 'en,bg',
                autoDisplay: false
            }, 'google_translate_element');
        }

        function changeLanguage(langCode, displayText) {
            var selectField = document.querySelector(".goog-te-combo");
            if (selectField) {
                selectField.value = langCode;
                selectField.dispatchEvent(new Event('change'));
                document.getElementById("currentLangText").innerText = displayText;
                localStorage.setItem('selectedUI_Lang', displayText);
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            var savedLang = localStorage.getItem('selectedUI_Lang');
            if (savedLang) {
                document.getElementById("currentLangText").innerText = savedLang;
            }
        });
    </script>
    <script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
    <style>
        /* Hide all Google Translate UI elements */
        .skiptranslate iframe { display: none !important; visibility: hidden !important; }
        iframe.goog-te-banner-frame { display: none !important; visibility: hidden !important; }
        .goog-te-banner-frame { display: none !important; visibility: hidden !important; }
        .goog-te-gadget-icon { display: none !important; visibility: hidden !important; }
        #goog-gt-tt, .goog-te-balloon-frame { display: none !important; visibility: hidden !important; }
        .goog-text-highlight { background-color: transparent !important; box-shadow: none !important; }
        .VIpgJd-ZVi9od-ORHb-OEVmcd { display: none !important; visibility: hidden !important; }
        .VIpgJd-ZVi9od-aZ2wEe-wOHMyf { display: none !important; visibility: hidden !important; }
        .VIpgJd-ZVi9od-aZ2wEe-wOHMyf-ti6hGc { display: none !important; visibility: hidden !important; }
        
        /* Prevent Google from shifting the page down */
        body { top: 0px !important; position: static !important; margin-top: 0px !important; }
        html { height: auto !important; }
        
        [data-theme='dark'] .custom-language-selector .btn-light {
            background-color: #212529;
            color: #fff;
            border-color: rgba(255,255,255,0.2) !important;
        }
        
        [data-theme='dark'] .custom-language-selector .dropdown-menu {
            background-color: #212529;
            border: 1px solid rgba(255,255,255,0.1) !important;
        }
        
        [data-theme='dark'] .custom-language-selector .dropdown-item {
            color: #fff;
        }
        
        [data-theme='dark'] .custom-language-selector .dropdown-item:hover {
            background-color: rgba(255,255,255,0.1);
        }
        
        .custom-language-selector .dropdown-item {
            transition: all 0.2s ease;
        }
        
        .custom-language-selector .dropdown-item:hover {
            transform: translateX(5px);
            color: var(--primary-color);
        }
    </style>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
