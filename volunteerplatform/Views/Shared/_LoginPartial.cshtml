@using Microsoft.AspNetCore.Identity
@using volunteerplatform.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var displayName = !string.IsNullOrEmpty(user?.FullName) ? user.FullName : (User.Identity?.Name ?? "User");

    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Hello @displayName
        </a>
        <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
            <li>
                <a class="dropdown-item" asp-area="" asp-controller="Manage" asp-action="Index">
                    <i class="bi bi-person me-2"></i> ACCOUNT
                </a>
            </li>
            
            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
            {
                <li>
                    <a class="dropdown-item text-danger fw-bold" asp-area="" asp-controller="Admin" asp-action="Index">
                        <i class="bi bi-shield-lock me-2"></i> ADMIN
                    </a>
                </li>
            }
            
            @if (User.IsInRole("Organizer"))
            {
                <li>
                    <a class="dropdown-item text-primary fw-bold" asp-area="" asp-controller="Initiatives" asp-action="MyInitiatives">
                        <i class="bi bi-calendar-event me-2"></i> MY MISSIONS
                    </a>
                </li>
            }
            
            @if (User.IsInRole("Volunteer"))
            {
                 <li>
                    <a class="dropdown-item text-primary fw-bold" asp-area="" asp-controller="Enrolments" asp-action="MyApplications">
                        <i class="bi bi-file-earmark-text me-2"></i> APPLICATIONS
                    </a>
                 </li>
            }
            
            <li><hr class="dropdown-divider"></li>
            <li>
                <form class="form-inline" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="dropdown-item text-dark">
                        <i class="bi bi-box-arrow-right me-2"></i> LOGOUT
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
    </li>
}
</ul>
